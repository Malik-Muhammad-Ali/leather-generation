# Copy this file to .env.local and fill in values from your Supabase project
# (Project Settings -> API). Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, bypasses Row Level Security.
# Used by admin API routes and the seed script. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
